# OpenAI
OPENAI_API_KEY=sk-...
# Vision-fähiges Modell (Standard: gpt-5-mini = genauere Portionsschätzung).
# Günstiger, aber unterschätzt Portionen: gpt-4.1-mini.
OPENAI_MODEL=gpt-5-mini

# Server
PORT=8787
# Host: 0.0.0.0 macht die API im lokalen Netz erreichbar (für iPhone/Shortcuts)
HOST=0.0.0.0

# Zugriffsschutz: Bearer-Token für /analyze.
# Leer lassen = kein Schutz (nur für rein lokale Tests).
# Web-App einmalig freischalten: http://<host>:8787/#token=DEIN_TOKEN öffnen
# (das Token landet per URL-Fragment nur lokal in der App, nie in Server-Logs).
API_TOKEN=

# Dexcom Share (optional): aktueller Glukosewert wird beim Analysieren geprüft.
# Zugangsdaten deines Dexcom-Share-Kontos (Follower muss eingerichtet sein).
# Region: ous = außerhalb USA (Europa), us = USA, jp = Japan.
DEXCOM_REGION=ous
DEXCOM_USERNAME=
DEXCOM_PASSWORD=
# Server-Cache für den Glukosewert in Sekunden (Dexcom liefert nur alle 5 Min neu).
GLUCOSE_CACHE_SECONDS=60

# Verlauf: jede Berechnung wird als JSON-Line gespeichert (ohne Foto).
# Pfad relativ zum Arbeitsverzeichnis; im Container liegt data/ auf einem Volume.
HISTORY_FILE=data/history.jsonl
# Wie viele Einträge /history zurückgibt (neueste zuerst). 0 = unbegrenzt.
HISTORY_MAX=0

# Pushover (Erinnerungen, optional). App-Token + dein User-Key aus pushover.net.
# PUSHOVER_DEVICE optional: an ein bestimmtes Gerät senden (leer = alle Geräte).
PUSHOVER_TOKEN=
PUSHOVER_USER=
PUSHOVER_DEVICE=

# Insulinfaktor: IE pro BE (1 BE = 12 g KH). Standard 0,5.
BOLUS_FACTOR_IU_PER_BE=0.5

# Blutzucker-Korrektur (nur wirksam, wenn Dexcom einen Wert liefert).
# Zielwert und Korrekturfaktor (1 IE senkt um X mg/dL). Standard: Ziel 100, Faktor 60
# -> bei 160 mg/dL +1 IE, bei 220 mg/dL +2 IE. Unter Ziel wird die Dosis reduziert.
CORRECTION_TARGET_MGDL=100
CORRECTION_ISF_MGDL=60

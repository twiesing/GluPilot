{
  "name": "glupilot",
  "version": "1.0.0",
  "description": "GluPilot – Mahlzeit fotografieren, Kohlenhydrate & Insulindosis schätzen (PWA + API).",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:web": "pnpm --filter web dev",
    "start": "tsx src/server.ts",
    "build": "tsc && pnpm --filter web build",
    "build:server": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.8.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "fastify": "^5.9.0",
    "openai": "^6.45.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
